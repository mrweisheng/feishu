# 飞书应用凭证(从 https://open.feishu.cn 获取)
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# HTTP 服务端口
PORT=4111

# SQLite 数据库路径(相对 server/ 目录)
DB_PATH=./data/messages.db

# LLM(Anthropic SDK 兼容端点,指向 MiniMax;所有 LLM 调用统一用此)
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
ANTHROPIC_API_KEY=
LLM_MODEL=MiniMax-M3

# 客资多维表格(留空 = 只入 SQLite,跳过飞书表格双写)
# 从 wiki URL 拿 app_token:  https://uipxp5adkne.feishu.cn/wiki/<NODE_TOKEN>
# 调 /open-apis/wiki/v2/spaces/get_node?token=<NODE_TOKEN> 拿 obj_token(就是 app_token)
BITABLE_CUSTOMER_APP_TOKEN=
# 调 /open-apis/bitable/v1/apps/<APP_TOKEN>/tables 拿 table_id
BITABLE_CUSTOMER_TABLE_ID=
# 表格链接(登记成功后回复里附上,用户点开直接看)
BITABLE_CUSTOMER_LINK=https://uipxp5adkne.feishu.cn/wiki/GAmHwqNGbi1ICzkAdErc9bLmnmb

# 提醒重启补偿窗口(毫秒,默认 1800000=30min):重启后过期但 < 该窗口的提醒补发,>= 的丢弃
REMINDER_RESEND_WINDOW_MS=1800000
