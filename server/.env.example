# 飞书应用凭证(从 https://open.feishu.cn 获取)
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# HTTP 服务端口
PORT=4111

# SQLite 数据库路径(相对 server/ 目录)
DB_PATH=./data/messages.db

# LLM(Anthropic SDK 兼容端点,指向 MiniMax;所有 LLM 调用统一用此)
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
ANTHROPIC_API_KEY=
LLM_MODEL=MiniMax-M3

# 多维表格双写(可选:留空则只入 SQLite)。app_token 从表格 URL .../base/{app_token} 复制
BITABLE_APP_TOKEN=
BITABLE_TABLE_ID=
# 多维表格链接(录入后回复里附上,便于点击查看)
BITABLE_LINK=

# 待办事项多维表格(可选:留空则跳过表格写入,只设提醒)。
# wiki 链接里的 node token 可直接当 app_token 用,table_id 从表格 URL 或 API 取
BITABLE_TODO_APP_TOKEN=
BITABLE_TODO_TABLE_ID=
# 待办表格链接(创建后回复里附上,便于点击查看)
BITABLE_TODO_LINK=
